programa {
  funcao inicio() {
    inteiro menor, idade
    escreva("Informe sua idade: ")
    leia(idade)
  
    se(idade < 18){
     escreva("Você é um menor de idade. Vai estudar vagabundo!!!")
    }senao{
      
       escreva("Você precisa de um emprego.")
    }

    escreva("\n") // comando para quebrar linha
  }
}
